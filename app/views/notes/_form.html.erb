<%= form_with(model: note, class: "contents") do |form| %>
  <% if note.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-4 py-3 rounded-lg border border-red-200 mb-6">
      <h2 class="font-bold mb-1"><%= pluralize(note.errors.count, "error") %> impidieron guardar:</h2>
      <ul class="list-disc list-inside text-sm">
        <% note.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="space-y-6 bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-2xl mx-auto mt-10">
    <div>
      <%= form.label :title, "Título de la Nota", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-3 border" %>
    </div>

    <div>
      <%= form.label :content, "Contenido", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= form.text_area :content, rows: 5, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-3 border" %>
    </div>

    <div class="flex items-center justify-between pt-4">
      <%= link_to "← Volver", notes_path, class: "text-sm font-medium text-gray-500 hover:text-gray-800" %>
      <%= form.submit "Guardar Nota", class: "rounded-lg py-3 px-6 bg-fuchsia-600 text-white font-bold cursor-pointer hover:bg-indigo-700 shadow-md transition" %>
    </div>
  </div>
<% end %>
