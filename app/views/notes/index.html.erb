<div class="max-w-5xl mx-auto mt-10">
  <div class="flex justify-between items-center mb-10">
    <div>
      <h1 class="text-4xl font-extrabold text-gray-900">Mis Notas</h1>
      <p class="text-gray-500">Gestiona tus ideas y recordatorios</p>
    </div>
    <%= link_to "Nueva Nota +", new_note_path, class: "bg-fuchsia-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-fuchsia-200 transition transform hover:-translate-y-1" %>
  </div>
  
  <div class="mb-8">
    <%= form_with url: notes_path, method: :get, class: "flex gap-2" do |f| %>
      <%= f.text_field :query, placeholder: "Buscar notas por título...", value: params[:query], 
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-3 border" %>
      <%= f.submit "Buscar", class: "bg-gray-800 text-white px-6 py-2 rounded-lg font-semibold hover:bg-black cursor-pointer transition" %>
      <% if params[:query].present? %>
        <%= link_to "Limpiar", notes_path, class: "text-gray-500 flex items-center hover:underline" %>
      <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% @notes.each do |note| %>
      <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
        <h2 class="text-xl font-bold text-gray-800 mb-2 truncate"><%= note.title %></h2>
        <p class="text-xs text-gray-400 mb-2">
          Publicado el: <%= note.created_at.strftime("%d/%m/%Y a las %H:%M") %>
        </p>
        <p class="text-gray-600 text-sm mb-6 line-clamp-3">
           <%= note.content %>
        </p>
        <%= link_to "Ver nota →", note, class: "text-indigo-600 font-semibold text-sm hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
